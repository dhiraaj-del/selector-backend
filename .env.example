# ── Razorpay ─────────────────────────────────────────────────────
# Get these from https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Database ──────────────────────────────────────────────────────
# Railway gives you this automatically when you add PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/selector

# ── Email ─────────────────────────────────────────────────────────
# Use a Gmail account. Enable 2FA then create an App Password:
# Google Account → Security → App Passwords → Generate
EMAIL_FROM=hello@crabculture.com
EMAIL_USER=your.gmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx   # Gmail app password (16 chars)

# ── App ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
PRODUCT_PRICE=1999
PRODUCT_NAME=Selector Pro
APP_SECRET=any_long_random_string_for_signing_keys
